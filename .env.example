# SeeCen runs without environment variables in demo mode:
# all data is seeded in the browser and persisted to localStorage.
#
# To connect your own Supabase backend instead (see SELF_HOSTING.md):
# 1. Create a project at https://supabase.com
# 2. Apply the SQL in supabase/migrations
# 3. Fill these in and restart the dev server
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional AI provider values for custom extensions:
# AI_PROVIDER_API_KEY=
# AI_PROVIDER_CHAT_URL=
# AI_PROVIDER_MODEL=
